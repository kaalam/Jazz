// This is a double inclusion! It is required for VSCode' Intellisense to work properly. This file is itself included in the
// .cpp file of the same name for unit testing. It has no effect on compilation.
#pragma once
#include "src/jazz_core/opcodes.h"


using namespace jazz_core;


// Tests
// -----

SCENARIO("Testing opcodes") {
	OpCodes opset = OpCodes(&LOGGER, &CONFIG);

	TensorTypes tt = {};

	String typ_names = "float,float16,uint16";

	REQUIRE(opset.fill_tensor_types(tt, typ_names));
	REQUIRE(tt.size() == 3);
	REQUIRE(tt[0].jazz_type == CELL_TYPE_SINGLE);

	typ_names = "bfloat16,ethereal";

	REQUIRE(!opset.fill_tensor_types(tt, typ_names));

	typ_names = "";
	tt = {};

	REQUIRE(opset.fill_tensor_types(tt, typ_names));
	REQUIRE(tt.size() == 0);

	typ_names = "floats";

	AttributeType ta = {};

	REQUIRE(opset.fill_attribute_type(ta, typ_names));

	REQUIRE(ta.jazz_type == CELL_TYPE_SINGLE);
	REQUIRE(ta.is_multi  == true);

	typ_names = "graph";

	REQUIRE(opset.fill_attribute_type(ta, typ_names));

	REQUIRE(ta.jazz_type == CELL_TYPE_ONNX_GRAPH);
	REQUIRE(ta.is_multi  == false);

	typ_names = "not_a_type";

	REQUIRE(!opset.fill_attribute_type(ta, typ_names));

	typ_names = "";

	REQUIRE(!opset.fill_attribute_type(ta, typ_names));

	REQUIRE(opset.start() == 0);

	REQUIRE(opset.ir_vers >= 10);
	REQUIRE(opset.onnx_conf.num_keys() > 5000);

	REQUIRE(opset.op_vers_latest >= 19);
	REQUIRE(opset.op_vers_current >= 19);
	REQUIRE(opset.op_vers_latest <= 99);
	REQUIRE(opset.op_vers_current <= 99);

	REQUIRE(!opset.set_opset_version(0));
	REQUIRE(!opset.set_opset_version(99));

	WHEN("opset is already populated, I can check some opcodes") {
		REQUIRE(opset.get((pChar) "Loretta") == nullptr);
		for (int vers = 1; vers < 11; vers++) {

			REQUIRE(opset.set_opset_version(vers));

			pOnnxOpCode p_op = opset.get((pChar) "ArgMin");

			REQUIRE(p_op != nullptr);

			REQUIRE(strcmp(p_op->name.name, (pChar) "ArgMin") == 0);
			REQUIRE(p_op->opset_version == 1);

			REQUIRE(p_op->attributes.size() == 2);

			REQUIRE(strcmp(p_op->attributes[0].name.name, (pChar) "axis") == 0);
			REQUIRE(p_op->attributes[0].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[0].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[1].name.name, (pChar) "keepdims") == 0);
			REQUIRE(p_op->attributes[1].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[1].type.is_multi == false);

			REQUIRE(p_op->inputs.size() == 1);
			REQUIRE(strcmp(p_op->inputs[0].name.name, (pChar) "data") == 0);
			REQUIRE(p_op->inputs[0].types.size() == 11);
			REQUIRE(p_op->inputs[0].types[0].jazz_type  == CELL_TYPE_DOUBLE);
			REQUIRE(p_op->inputs[0].types[1].jazz_type  == CELL_TYPE_SINGLE);
			REQUIRE(p_op->inputs[0].types[2].jazz_type  == CELL_TYPE_FLOAT16);
			REQUIRE(p_op->inputs[0].types[10].jazz_type == CELL_TYPE_BYTE);

			REQUIRE(p_op->outputs.size() == 1);
			REQUIRE(strcmp(p_op->outputs[0].name.name, (pChar) "reduced") == 0);
			REQUIRE(p_op->outputs[0].types.size() == 1);
			REQUIRE(p_op->outputs[0].types[0].jazz_type == CELL_TYPE_LONG_INTEGER);
		}

		for (int vers = 13; vers < 20; vers++) {

			REQUIRE(opset.set_opset_version(vers));

			pOnnxOpCode p_op = opset.get((pChar) "ArgMin");

			REQUIRE(p_op != nullptr);

			REQUIRE(strcmp(p_op->name.name, (pChar) "ArgMin") == 0);
			REQUIRE(p_op->opset_version == 13);

			REQUIRE(p_op->attributes.size() == 3);

			REQUIRE(strcmp(p_op->attributes[0].name.name, (pChar) "axis") == 0);
			REQUIRE(p_op->attributes[0].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[0].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[1].name.name, (pChar) "keepdims") == 0);
			REQUIRE(p_op->attributes[1].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[1].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[2].name.name, (pChar) "select_last_index") == 0);
			REQUIRE(p_op->attributes[2].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[2].type.is_multi == false);

			REQUIRE(p_op->inputs.size() == 1);
			REQUIRE(strcmp(p_op->inputs[0].name.name, (pChar) "data") == 0);
			REQUIRE(p_op->inputs[0].types.size() == 12);
			REQUIRE(p_op->inputs[0].types[0].jazz_type  == CELL_TYPE_BFLOAT16);
			REQUIRE(p_op->inputs[0].types[1].jazz_type  == CELL_TYPE_DOUBLE);
			REQUIRE(p_op->inputs[0].types[2].jazz_type  == CELL_TYPE_SINGLE);
			REQUIRE(p_op->inputs[0].types[3].jazz_type  == CELL_TYPE_FLOAT16);
			REQUIRE(p_op->inputs[0].types[11].jazz_type == CELL_TYPE_BYTE);

			REQUIRE(p_op->outputs.size() == 1);
			REQUIRE(strcmp(p_op->outputs[0].name.name, (pChar) "reduced") == 0);
			REQUIRE(p_op->outputs[0].types.size() == 1);
			REQUIRE(p_op->outputs[0].types[0].jazz_type == CELL_TYPE_LONG_INTEGER);
		}

		REQUIRE(opset.set_opset_version(19));

		pOnnxOpCode p_op = opset.get((pChar) "BatchNormalization");

		REQUIRE(p_op != nullptr);

		REQUIRE(strcmp(p_op->name.name, (pChar) "BatchNormalization") == 0);
		REQUIRE(p_op->opset_version == 15);

		REQUIRE(p_op->attributes.size() == 3);
		REQUIRE(strcmp(p_op->attributes[0].name.name, (pChar) "epsilon") == 0);
		REQUIRE(strcmp(p_op->attributes[1].name.name, (pChar) "momentum") == 0);
		REQUIRE(strcmp(p_op->attributes[2].name.name, (pChar) "training_mode") == 0);

		REQUIRE(p_op->inputs.size() == 5);
		REQUIRE(strcmp(p_op->inputs[0].name.name, (pChar) "X") == 0);
		REQUIRE(strcmp(p_op->inputs[1].name.name, (pChar) "scale") == 0);
		REQUIRE(strcmp(p_op->inputs[2].name.name, (pChar) "B") == 0);
		REQUIRE(strcmp(p_op->inputs[3].name.name, (pChar) "input_mean") == 0);
		REQUIRE(strcmp(p_op->inputs[4].name.name, (pChar) "input_var") == 0);

		REQUIRE(p_op->outputs.size() == 3);
		REQUIRE(strcmp(p_op->outputs[0].name.name, (pChar) "Y") == 0);
		REQUIRE(strcmp(p_op->outputs[1].name.name, (pChar) "running_mean") == 0);
		REQUIRE(strcmp(p_op->outputs[2].name.name, (pChar) "running_var") == 0);

		p_op = opset.get((pChar) "If");

		REQUIRE(p_op != nullptr);

		REQUIRE(strcmp(p_op->name.name, (pChar) "If") == 0);
		REQUIRE(p_op->opset_version == 19);

		REQUIRE(p_op->attributes.size() == 2);
		REQUIRE(strcmp(p_op->attributes[0].name.name, (pChar) "else_branch") == 0);
		REQUIRE(p_op->attributes[0].type.jazz_type == CELL_TYPE_ONNX_GRAPH);
		REQUIRE(p_op->attributes[0].type.is_multi == false);
		REQUIRE(strcmp(p_op->attributes[1].name.name, (pChar) "then_branch") == 0);
		REQUIRE(p_op->attributes[1].type.jazz_type == CELL_TYPE_ONNX_GRAPH);
		REQUIRE(p_op->attributes[1].type.is_multi == false);

		REQUIRE(p_op->inputs.size() == 1);
		REQUIRE(strcmp(p_op->inputs[0].name.name, (pChar) "cond") == 0);
		REQUIRE(p_op->inputs[0].types.size() == 1);
		REQUIRE(p_op->inputs[0].types[0].jazz_type  == CELL_TYPE_BYTE_BOOLEAN);

		REQUIRE(p_op->outputs.size() == 1);
		REQUIRE(strcmp(p_op->outputs[0].name.name, (pChar) "outputs") == 0);
		REQUIRE(p_op->outputs[0].types.size() == 14);

		for (int vers = 1; vers < 7; vers++) {
			REQUIRE(opset.set_opset_version(vers));

			pOnnxOpCode p_op = opset.get((pChar) "LSTM");

			REQUIRE(p_op != nullptr);

			REQUIRE(strcmp(p_op->name.name, (pChar) "LSTM") == 0);
			REQUIRE(p_op->opset_version == 1);

			REQUIRE(p_op->attributes.size() == 8);

			REQUIRE(strcmp(p_op->attributes[0].name.name, (pChar) "activation_alpha") == 0);
			REQUIRE(p_op->attributes[0].type.jazz_type == CELL_TYPE_SINGLE);
			REQUIRE(p_op->attributes[0].type.is_multi == true);
			REQUIRE(strcmp(p_op->attributes[1].name.name, (pChar) "activation_beta") == 0);
			REQUIRE(p_op->attributes[1].type.jazz_type == CELL_TYPE_SINGLE);
			REQUIRE(p_op->attributes[1].type.is_multi == true);
			REQUIRE(strcmp(p_op->attributes[2].name.name, (pChar) "activations") == 0);
			REQUIRE(p_op->attributes[2].type.jazz_type == CELL_TYPE_STRING);
			REQUIRE(p_op->attributes[2].type.is_multi == true);
			REQUIRE(strcmp(p_op->attributes[3].name.name, (pChar) "clip") == 0);
			REQUIRE(p_op->attributes[3].type.jazz_type == CELL_TYPE_SINGLE);
			REQUIRE(p_op->attributes[3].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[4].name.name, (pChar) "direction") == 0);
			REQUIRE(p_op->attributes[4].type.jazz_type == CELL_TYPE_STRING);
			REQUIRE(p_op->attributes[4].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[5].name.name, (pChar) "hidden_size") == 0);
			REQUIRE(p_op->attributes[5].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[5].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[6].name.name, (pChar) "input_forget") == 0);
			REQUIRE(p_op->attributes[6].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[6].type.is_multi == false);
			REQUIRE(strcmp(p_op->attributes[7].name.name, (pChar) "output_sequence") == 0);
			REQUIRE(p_op->attributes[7].type.jazz_type == CELL_TYPE_LONG_INTEGER);
			REQUIRE(p_op->attributes[7].type.is_multi == false);

			REQUIRE(p_op->inputs.size() == 8);
			REQUIRE(p_op->outputs.size() == 3);
		}

	}

	REQUIRE(opset.shut_down() == 0);
}


SCENARIO("Coverage-focused opcodes error branches") {
	auto fill_should_fail = [&](std::initializer_list<std::pair<const char *, const char *>> keys) {
		ConfigFile conf(nullptr);
		OpCodes ops = OpCodes(&LOGGER, &conf);

		for (const auto &it : keys) {
			ops.onnx_conf.debug_put(it.first, it.second);
		}

		OnnxOpCode op((pChar) "Mini", 1, OnnxParameters(), OnnxParameters(), OnnxAttributes());

		return !ops.fill_op_code(op);
	};

	WHEN("start() finds missing or broken configuration") {
		ConfigFile conf_missing_ir(nullptr);
		conf_missing_ir.debug_put("ONNX_OPCODE_DEFS_FN", "/tmp/jzz_unit_missing_ir.ini");

		OpCodes ops_missing_ir = OpCodes(&LOGGER, &conf_missing_ir);

		ops_missing_ir.log_error_level = LOG_DEBUG;
		REQUIRE(ops_missing_ir.start() == SERVICE_ERROR_BAD_CONFIG);

		ConfigFile conf_missing_defs(nullptr);
		conf_missing_defs.debug_put("ONNX_IR_VERSION", "10");

		OpCodes ops_missing_defs = OpCodes(&LOGGER, &conf_missing_defs);

		ops_missing_defs.log_error_level = LOG_DEBUG;
		REQUIRE(ops_missing_defs.start() == SERVICE_ERROR_BAD_CONFIG);

		ConfigFile conf_missing_file(nullptr);
		conf_missing_file.debug_put("ONNX_IR_VERSION", "10");
		conf_missing_file.debug_put("ONNX_OPCODE_DEFS_FN", "/tmp/jzz_unit_opcodes_missing_file.ini");

		OpCodes ops_missing_file = OpCodes(&LOGGER, &conf_missing_file);

		ops_missing_file.log_error_level = LOG_DEBUG;
		REQUIRE(ops_missing_file.start() == SERVICE_ERROR_IO_ERROR);

		char fn_no_name_vers[MAX_FILE_OR_URL_SIZE];
		sprintf(fn_no_name_vers, "/tmp/jzz_unit_opcodes_no_name_vers_%i.ini", (int) getpid());
		remove(fn_no_name_vers);

		std::ofstream fh_no_name_vers;
		fh_no_name_vers.open(fn_no_name_vers);
		fh_no_name_vers << "__names = Mini\n";
		fh_no_name_vers << "Mini.1.num_inputs = 0\n";
		fh_no_name_vers.close();

		ConfigFile conf_no_name_vers(nullptr);
		conf_no_name_vers.debug_put("ONNX_IR_VERSION", "10");
		conf_no_name_vers.debug_put("ONNX_OPCODE_DEFS_FN", fn_no_name_vers);

		OpCodes ops_no_name_vers = OpCodes(&LOGGER, &conf_no_name_vers);

		ops_no_name_vers.log_error_level = LOG_DEBUG;
		REQUIRE(ops_no_name_vers.start() == SERVICE_ERROR_IO_ERROR);

		remove(fn_no_name_vers);
	}

	WHEN("build_opcode_dict() fails in malformed and incomplete definitions") {
		ConfigFile conf_missing_name_vers(nullptr);
		OpCodes ops_missing_name_vers = OpCodes(&LOGGER, &conf_missing_name_vers);

		REQUIRE(!ops_missing_name_vers.build_opcode_dict());

		ConfigFile conf_bad_name_vers(nullptr);
		OpCodes ops_bad_name_vers = OpCodes(&LOGGER, &conf_bad_name_vers);
		ops_bad_name_vers.onnx_conf.debug_put("__name_vers", "Mini.x");

		REQUIRE(!ops_bad_name_vers.build_opcode_dict());

		ConfigFile conf_incomplete_opcode(nullptr);
		OpCodes ops_incomplete_opcode = OpCodes(&LOGGER, &conf_incomplete_opcode);
		ops_incomplete_opcode.onnx_conf.debug_put("__name_vers", "Mini.1");

		REQUIRE(!ops_incomplete_opcode.build_opcode_dict());
	}

	WHEN("fill_op_code() hits early returns for missing keys and invalid types") {
		REQUIRE(fill_should_fail({}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "1"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "1"}, {"Mini.1.input.0.name", "x"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "1"}, {"Mini.1.input.0.name", "x"}, {"Mini.1.input.0.tensor_types", "ethereal"}}));

		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "1"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "1"}, {"Mini.1.output.0.name", "y"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "1"}, {"Mini.1.output.0.name", "y"}, {"Mini.1.output.0.tensor_types", "ethereal"}}));

		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "0"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "0"}, {"Mini.1.num_attributes", "1"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "0"}, {"Mini.1.num_attributes", "1"}, {"Mini.1.attribute.0.name", "axis"}}));
		REQUIRE(fill_should_fail({{"Mini.1.num_inputs", "0"}, {"Mini.1.num_outputs", "0"}, {"Mini.1.num_attributes", "1"}, {"Mini.1.attribute.0.name", "axis"}, {"Mini.1.attribute.0.type", "ethereal"}}));
	}

	WHEN("fill_all_dict_versions() fails without __names") {
		ConfigFile conf_no_names(nullptr);
		OpCodes ops_no_names = OpCodes(&LOGGER, &conf_no_names);

		REQUIRE(!ops_no_names.fill_all_dict_versions());
	}
}
